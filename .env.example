# ── REQUIRED ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here   # from @BotFather
OPENAI_API_KEY=your_openai_api_key_here           # required for RAG + Vision

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow ALL users (open bot) — a warning is logged at startup.
ALLOWED_USER_IDS=123456789,987654321

# ── RAG / LLM ────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini

# Set USE_OLLAMA=true to use a local Ollama model as fallback (or primary).
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434   # use http://ollama:11434 inside Docker
OLLAMA_MODEL=llama3.2

# ── EMBEDDINGS & VECTOR STORE ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
DB_PATH=.db/genai_bot.db
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K=3

# ── CONVERSATION & CACHE ─────────────────────────────────────────────────────
MAX_HISTORY=10        # last N exchanges sent as context to LLM
CACHE_TTL_HOURS=24    # how long query results are cached

# ── OPTIONAL: WEB SEARCH ─────────────────────────────────────────────────────
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=       # required only if ENABLE_WEB_SEARCH=true

# ── LIMITS & LOGGING ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
MAX_IMAGE_SIZE_MB=20
LOG_LEVEL=INFO
